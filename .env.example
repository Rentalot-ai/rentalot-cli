# Rentalot CLI — E2E test credentials
# Copy to .env and fill in real values.
# Generate API keys via: cd ../rentalot && make seed-test-users (dev) / make seed-test-users-prod (prod)

# Dev environment (localhost or preview)
RENTALOT_E2E_DEV_BASE_URL=http://localhost:3000
RENTALOT_E2E_DEV_API_KEY=ra_REPLACE_WITH_DEV_KEY

# Production environment
RENTALOT_E2E_PROD_BASE_URL=https://rentalot.ai
RENTALOT_E2E_PROD_API_KEY=ra_REPLACE_WITH_PROD_KEY
